@model AlMal.Admin.ViewModels.NewsDetailViewModel
@{
    ViewData["Title"] = "تفاصيل الخبر";
}

@* رابط العودة *@
<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-right me-1"></i>العودة إلى قائمة الأخبار
    </a>
</div>

<div class="row g-4">
    @* العمود الرئيسي *@
    <div class="col-lg-8">
        @* عنوان الخبر ومعلومات أساسية *@
        <div class="card mb-4">
            <div class="card-body">
                <h2 class="mb-3">@Model.TitleAr</h2>
                <div class="d-flex flex-wrap gap-3 text-muted mb-3">
                    <span>
                        <i class="bi bi-building me-1"></i>
                        @if (!string.IsNullOrEmpty(Model.SourceUrl))
                        {
                            <a href="@Model.SourceUrl" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                                @Model.Source
                                <i class="bi bi-box-arrow-up-left ms-1 small"></i>
                            </a>
                        }
                        else
                        {
                            @Model.Source
                        }
                    </span>
                    <span>
                        <i class="bi bi-calendar3 me-1"></i>@Model.PublishedAt.ToString("yyyy/MM/dd HH:mm")
                    </span>
                </div>

                @* صورة الخبر *@
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-3">
                        <img src="@Model.ImageUrl" alt="@Model.TitleAr"
                             class="img-fluid rounded" style="max-height: 400px; object-fit: cover; width: 100%;" />
                    </div>
                }
            </div>
        </div>

        @* ملخص الذكاء الاصطناعي *@
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-robot me-2"></i>ملخص الذكاء الاصطناعي
                </h5>
            </div>
            <div class="card-body">
                @if (Model.IsProcessed && !string.IsNullOrEmpty(Model.Summary))
                {
                    <p class="mb-0" style="line-height: 1.8;">@Model.Summary</p>
                }
                else
                {
                    <div class="text-center text-muted py-3">
                        <i class="bi bi-hourglass-split fs-3 d-block mb-2"></i>
                        <span>لم تتم المعالجة</span>
                    </div>
                }
            </div>
        </div>

        @* بيانات السياق *@
        @if (!string.IsNullOrEmpty(Model.ContextData))
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-braces me-2"></i>بيانات السياق
                    </h5>
                </div>
                <div class="card-body">
                    <pre class="mb-0" dir="ltr" style="background-color: var(--input-bg); border: 1px solid var(--input-border); border-radius: 0.5rem; padding: 1rem; color: var(--body-color); font-family: var(--font-mono); font-size: 0.85rem; overflow-x: auto; white-space: pre-wrap; word-wrap: break-word;">@Model.ContextData</pre>
                </div>
            </div>
        }
    </div>

    @* العمود الجانبي *@
    <div class="col-lg-4">
        @* تصنيف المشاعر *@
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-emoji-smile me-2"></i>التصنيف
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3 text-center">
                    @if (Model.Sentiment == AlMal.Domain.Enums.Sentiment.Positive)
                    {
                        <span class="badge fs-6 px-3 py-2" style="background-color: rgba(34,197,94,0.15); color: var(--clr-positive);">
                            <i class="bi bi-arrow-up-circle me-1"></i>إيجابي
                        </span>
                    }
                    else if (Model.Sentiment == AlMal.Domain.Enums.Sentiment.Negative)
                    {
                        <span class="badge fs-6 px-3 py-2" style="background-color: rgba(239,68,68,0.15); color: var(--clr-negative);">
                            <i class="bi bi-arrow-down-circle me-1"></i>سلبي
                        </span>
                    }
                    else
                    {
                        <span class="badge fs-6 px-3 py-2" style="background-color: rgba(156,163,175,0.15); color: var(--muted-color);">
                            <i class="bi bi-dash-circle me-1"></i>محايد
                        </span>
                    }
                </div>

                @* تغيير التصنيف *@
                <form asp-action="OverrideSentiment" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <label class="form-label">تغيير التصنيف يدوياً</label>
                    <div class="d-flex gap-2">
                        <select name="sentiment" class="form-select">
                            <option value="Positive" selected="@(Model.Sentiment == AlMal.Domain.Enums.Sentiment.Positive)">إيجابي</option>
                            <option value="Negative" selected="@(Model.Sentiment == AlMal.Domain.Enums.Sentiment.Negative)">سلبي</option>
                            <option value="Neutral" selected="@(Model.Sentiment == AlMal.Domain.Enums.Sentiment.Neutral)">محايد</option>
                        </select>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        @* حالة المعالجة *@
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-gear me-2"></i>حالة المعالجة
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3 text-center">
                    @if (Model.IsProcessed)
                    {
                        <span class="badge badge-active fs-6 px-3 py-2">
                            <i class="bi bi-check-circle me-1"></i>تمت المعالجة
                        </span>
                    }
                    else
                    {
                        <span class="badge badge-inactive fs-6 px-3 py-2">
                            <i class="bi bi-clock me-1"></i>لم تتم المعالجة
                        </span>
                    }
                </div>
                <form asp-action="Reprocess" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-warning w-100"
                            onclick="return confirm('هل تريد إعادة معالجة هذا الخبر؟');">
                        <i class="bi bi-arrow-repeat me-1"></i>إعادة المعالجة
                    </button>
                </form>
            </div>
        </div>

        @* الأسهم ذات الصلة *@
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-graph-up me-2"></i>الأسهم ذات الصلة
                </h5>
            </div>
            <div class="card-body">
                @if (Model.RelatedStocks.Count > 0)
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var stock in Model.RelatedStocks)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center"
                                style="background-color: transparent; border-color: var(--card-border);">
                                <span>@stock.NameAr</span>
                                <span class="badge bg-secondary font-monospace">@stock.Symbol</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-center text-muted py-3">
                        <i class="bi bi-info-circle me-1"></i>لا توجد أسهم مرتبطة
                    </div>
                }
            </div>
        </div>

        @* زر الحذف *@
        <div class="card border-danger">
            <div class="card-body">
                <h5 class="text-danger mb-3">
                    <i class="bi bi-exclamation-triangle me-2"></i>منطقة الخطر
                </h5>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger w-100"
                            onclick="return confirm('هل أنت متأكد من حذف هذا الخبر؟ لا يمكن التراجع عن هذا الإجراء.');">
                        <i class="bi bi-trash me-1"></i>حذف الخبر
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
