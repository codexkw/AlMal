<!DOCTYPE html>
<html dir="rtl" lang="ar" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - لوحة تحكم قناة المال</title>

    @* Google Fonts: IBM Plex Sans Arabic + IBM Plex Mono *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />

    @* Bootstrap 5.3 RTL *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
          integrity="sha384-dpuaG1suU0eT09tx5plTaGMLBsfDLzUCCUXOY2v/bp+21CWDS4ZEBdmsBgHwMYGn"
          crossorigin="anonymous" />

    @* Bootstrap Icons *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --clr-primary: #4F0E5E;
            --clr-accent: #FC4A04;
            --clr-positive: #22C55E;
            --clr-negative: #EF4444;
            --clr-dark: #1A1A2E;
            --clr-light: #F5F5F5;
            --font-primary: 'IBM Plex Sans Arabic', 'Noto Sans Arabic', sans-serif;
            --font-mono: 'IBM Plex Mono', monospace;

            --body-bg: #0f0f1a;
            --body-color: #e8e8ec;
            --card-bg: #1a1a2e;
            --card-border: #2a2a40;
            --muted-color: #9ca3af;
            --input-bg: #1e1e32;
            --input-border: #3a3a52;
            --input-color: #e8e8ec;
            --hover-bg: rgba(255, 255, 255, 0.05);
        }

        [data-theme="light"] {
            --body-bg: #f8f9fa;
            --body-color: #212529;
            --card-bg: #ffffff;
            --card-border: #dee2e6;
            --muted-color: #6c757d;
            --input-bg: #ffffff;
            --input-border: #ced4da;
            --input-color: #212529;
            --hover-bg: rgba(0, 0, 0, 0.04);
        }

        html {
            font-size: 14px;
            direction: rtl;
        }

        @@media (min-width: 768px) {
            html { font-size: 16px; }
        }

        body {
            font-family: var(--font-primary);
            background-color: var(--body-bg);
            color: var(--body-color);
            margin: 0;
            min-height: 100vh;
        }

        .admin-sidebar {
            position: fixed;
            top: 0;
            right: 0;
            width: 260px;
            height: 100vh;
            background-color: var(--clr-primary);
            color: #fff;
            overflow-y: auto;
            z-index: 1040;
            transition: transform 0.3s ease;
        }

        .admin-sidebar .sidebar-brand {
            padding: 1.25rem 1rem;
            font-size: 1.2rem;
            font-weight: 700;
            border-bottom: 1px solid rgba(255,255,255,0.15);
            display: flex;
            align-items: center;
        }

        .admin-sidebar .sidebar-nav {
            list-style: none;
            padding: 0.5rem 0;
            margin: 0;
        }

        .admin-sidebar .sidebar-nav-item a {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding: 0.7rem 1.25rem;
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.9rem;
            transition: background-color 0.2s ease, color 0.2s ease;
        }

        .admin-sidebar .sidebar-nav-item a:hover,
        .admin-sidebar .sidebar-nav-item a.active {
            background-color: rgba(255,255,255,0.12);
            color: #ffffff;
        }

        .admin-sidebar .sidebar-nav-item a i {
            font-size: 1.1rem;
            width: 1.5rem;
            text-align: center;
        }

        .admin-content {
            margin-right: 260px;
            min-height: 100vh;
            padding: 1.5rem 2rem;
        }

        .admin-header {
            padding: 1rem 0;
            border-bottom: 1px solid var(--card-border);
            margin-bottom: 1.5rem;
        }

        .admin-header h1 {
            font-size: 1.4rem;
            font-weight: 700;
            margin: 0;
        }

        .card {
            background-color: var(--card-bg);
            border-color: var(--card-border);
            border-radius: 0.75rem;
        }

        .card-header {
            background-color: transparent;
            border-bottom-color: var(--card-border);
        }

        .table {
            color: var(--body-color);
        }

        .table > thead {
            border-bottom: 2px solid var(--card-border);
        }

        .table > tbody > tr {
            border-bottom: 1px solid var(--card-border);
        }

        .table > tbody > tr:hover {
            background-color: var(--hover-bg);
        }

        .form-control, .form-select {
            background-color: var(--input-bg);
            border-color: var(--input-border);
            color: var(--input-color);
        }

        .form-control:focus, .form-select:focus {
            background-color: var(--input-bg);
            border-color: var(--clr-primary);
            color: var(--input-color);
            box-shadow: 0 0 0 0.2rem rgba(79,14,94,0.25);
        }

        .form-control::placeholder {
            color: var(--muted-color);
        }

        .btn-primary {
            background-color: var(--clr-primary);
            border-color: var(--clr-primary);
        }

        .btn-primary:hover {
            background-color: #3d0b49;
            border-color: #3d0b49;
        }

        .btn-accent {
            background-color: var(--clr-accent);
            border-color: var(--clr-accent);
            color: #fff;
        }

        .btn-accent:hover {
            background-color: #e04303;
            border-color: #e04303;
            color: #fff;
        }

        .text-positive { color: var(--clr-positive) !important; }
        .text-negative { color: var(--clr-negative) !important; }

        .badge-active {
            background-color: rgba(34,197,94,0.15);
            color: var(--clr-positive);
        }

        .badge-inactive {
            background-color: rgba(239,68,68,0.15);
            color: var(--clr-negative);
        }

        @@media (max-width: 991.98px) {
            .admin-sidebar {
                transform: translateX(100%);
            }
            .admin-sidebar.show {
                transform: translateX(0);
            }
            .admin-content {
                margin-right: 0;
            }
        }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--body-bg); }
        ::-webkit-scrollbar-thumb { background: var(--card-border); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--muted-color); }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @* الشريط الجانبي *@
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-brand">
            <i class="bi bi-shield-lock ms-2"></i>لوحة تحكم قناة المال
        </div>
        <ul class="sidebar-nav">
            <li class="sidebar-nav-item">
                <a href="/" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i>لوحة التحكم
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a href="/Stocks" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Stocks" ? "active" : "")">
                    <i class="bi bi-graph-up"></i>الأسهم
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a href="/Sectors" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Sectors" ? "active" : "")">
                    <i class="bi bi-grid-3x3-gap"></i>القطاعات
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a href="/Moderation" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Moderation" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="bi bi-shield-exclamation"></i>الإشراف
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a href="/Moderation/Users" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Moderation" && ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")">
                    <i class="bi bi-people-fill"></i>المستخدمون
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a href="#">
                    <i class="bi bi-file-earmark-text"></i>المحتوى
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a href="/News" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "News" ? "active" : "")">
                    <i class="bi bi-newspaper"></i>الأخبار
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a href="/Academy" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Academy" ? "active" : "")">
                    <i class="bi bi-mortarboard"></i>الأكاديمية
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a href="#">
                    <i class="bi bi-bell"></i>التنبيهات
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a href="#">
                    <i class="bi bi-bar-chart-line"></i>الإحصائيات
                </a>
            </li>
            <li class="sidebar-nav-item">
                <a href="#">
                    <i class="bi bi-gear"></i>الإعدادات
                </a>
            </li>
        </ul>
    </aside>

    @* منطقة المحتوى الرئيسية *@
    <div class="admin-content">
        @* رأس الصفحة *@
        <header class="admin-header d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-link text-light d-lg-none p-0 fs-4"
                        type="button"
                        onclick="document.getElementById('adminSidebar').classList.toggle('show')"
                        aria-label="القائمة الجانبية">
                    <i class="bi bi-list"></i>
                </button>
                <h1>@(ViewData["Title"] ?? "لوحة التحكم")</h1>
            </div>
            <div class="d-flex align-items-center gap-2">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <span class="text-muted small">@User.Identity.Name</span>
                }
            </div>
        </header>

        @* رسائل التنبيه *@
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="إغلاق"></button>
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="إغلاق"></button>
            </div>
        }

        @* محتوى الصفحة *@
        <main role="main">
            @RenderBody()
        </main>
    </div>

    @* Bootstrap Bundle JS *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
