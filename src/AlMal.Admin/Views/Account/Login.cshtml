@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تسجيل الدخول - لوحة تحكم قناة المال</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
          integrity="sha384-dpuaG1suU0eT09tx5plTaGMLBsfDLzUCCUXOY2j/LSvXYuG6Bqs43ALlhIqAJVRb"
          crossorigin="anonymous" />
    <style>
        :root {
            --clr-primary: #4F0E5E;
            --clr-accent: #FC4A04;
            --clr-dark: #1A1A2E;
        }
        body {
            font-family: 'IBM Plex Sans Arabic', sans-serif;
            background: linear-gradient(135deg, var(--clr-dark) 0%, #16213e 50%, var(--clr-primary) 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            width: 100%;
            max-width: 420px;
            padding: 2.5rem;
        }
        .login-card h2 {
            color: #fff;
            font-weight: 700;
        }
        .login-card .subtitle {
            color: rgba(255, 255, 255, 0.6);
            font-size: 0.9rem;
        }
        .form-control {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: #fff;
            padding: 0.75rem 1rem;
        }
        .form-control:focus {
            background: rgba(255, 255, 255, 0.12);
            border-color: var(--clr-accent);
            color: #fff;
            box-shadow: 0 0 0 0.2rem rgba(252, 74, 4, 0.25);
        }
        .form-control::placeholder { color: rgba(255, 255, 255, 0.4); }
        .form-label { color: rgba(255, 255, 255, 0.8); font-weight: 500; }
        .form-check-label { color: rgba(255, 255, 255, 0.7); }
        .form-check-input { background-color: rgba(255, 255, 255, 0.1); border-color: rgba(255, 255, 255, 0.3); }
        .form-check-input:checked { background-color: var(--clr-accent); border-color: var(--clr-accent); }
        .btn-login {
            background: var(--clr-accent);
            border: none;
            color: #fff;
            padding: 0.75rem;
            font-weight: 600;
            font-size: 1.05rem;
            border-radius: 10px;
            transition: all 0.2s;
        }
        .btn-login:hover { background: #e04300; color: #fff; transform: translateY(-1px); }
        .logo-text {
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--clr-accent), #ff6b35);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-4">
            <span class="logo-text">قناة المال</span>
            <h2 class="mt-2 mb-1">لوحة التحكم</h2>
            <p class="subtitle">سجل دخولك للوصول إلى لوحة الإدارة</p>
        </div>

        @if (ViewData["Error"] is string error)
        {
            <div class="alert alert-danger py-2" role="alert">@error</div>
        }

        <form method="post" asp-action="Login" asp-controller="Account">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            <div class="mb-3">
                <label class="form-label">البريد الإلكتروني</label>
                <input name="email" type="email" class="form-control" placeholder="admin@almal.com" dir="ltr" required autofocus />
            </div>

            <div class="mb-3">
                <label class="form-label">كلمة المرور</label>
                <input name="password" type="password" class="form-control" dir="ltr" required />
            </div>

            <div class="mb-4 form-check">
                <input name="rememberMe" type="checkbox" class="form-check-input" value="true" />
                <label class="form-check-label">تذكرني</label>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-login">تسجيل الدخول</button>
            </div>
        </form>
    </div>
</body>
</html>
