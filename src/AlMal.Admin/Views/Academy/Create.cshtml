@model AlMal.Admin.ViewModels.CourseEditViewModel
@{
    ViewData["Title"] = "إنشاء دورة جديدة";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">إنشاء دورة جديدة</h5>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-right me-1"></i>العودة
                </a>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        @* عنوان الدورة *@
                        <div class="col-12">
                            <label asp-for="TitleAr" class="form-label">عنوان الدورة <span class="text-danger">*</span></label>
                            <input asp-for="TitleAr" class="form-control" placeholder="مثال: أساسيات الاستثمار في البورصة" />
                            <span asp-validation-for="TitleAr" class="text-danger small"></span>
                        </div>

                        @* الوصف *@
                        <div class="col-12">
                            <label asp-for="DescriptionAr" class="form-label">الوصف</label>
                            <textarea asp-for="DescriptionAr" class="form-control" rows="4"
                                      placeholder="وصف تفصيلي للدورة..."></textarea>
                            <span asp-validation-for="DescriptionAr" class="text-danger small"></span>
                        </div>

                        @* رابط الصورة المصغرة *@
                        <div class="col-12">
                            <label asp-for="ThumbnailUrl" class="form-label">رابط الصورة المصغرة</label>
                            <input asp-for="ThumbnailUrl" class="form-control" dir="ltr" placeholder="https://..." />
                            <span asp-validation-for="ThumbnailUrl" class="text-danger small"></span>
                        </div>

                        @* مجانية / مدفوعة *@
                        <div class="col-md-6">
                            <div class="form-check form-switch mt-4">
                                <input asp-for="IsFree" class="form-check-input" type="checkbox" role="switch" id="isFreeSwitch" />
                                <label asp-for="IsFree" class="form-check-label">مجانية</label>
                            </div>
                        </div>

                        @* السعر *@
                        <div class="col-md-6" id="priceField">
                            <label asp-for="Price" class="form-label">السعر (د.ك)</label>
                            <input asp-for="Price" class="form-control" type="number" step="0.001" dir="ltr" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        @* الترتيب *@
                        <div class="col-md-6">
                            <label asp-for="SortOrder" class="form-label">الترتيب</label>
                            <input asp-for="SortOrder" class="form-control" type="number" dir="ltr" />
                            <span asp-validation-for="SortOrder" class="text-danger small"></span>
                        </div>

                        @* حالة النشر *@
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check form-switch">
                                <input asp-for="IsPublished" class="form-check-input" type="checkbox" role="switch" />
                                <label asp-for="IsPublished" class="form-check-label">منشورة</label>
                            </div>
                        </div>
                    </div>

                    @* أزرار الإجراءات *@
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-accent">
                            <i class="bi bi-plus-lg me-1"></i>إنشاء
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('isFreeSwitch').addEventListener('change', function () {
            document.getElementById('priceField').style.display = this.checked ? 'none' : 'block';
        });
        // Initial state
        if (document.getElementById('isFreeSwitch').checked) {
            document.getElementById('priceField').style.display = 'none';
        }
    </script>
}
