@model AlMal.Admin.ViewModels.EnrollmentStatsViewModel
@{
    ViewData["Title"] = "إحصائيات الأكاديمية";
}

@* رأس الصفحة *@
<div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">الدورات</a></li>
                <li class="breadcrumb-item active">الإحصائيات</li>
            </ol>
        </nav>
    </div>
</div>

@* بطاقات الإحصائيات الرئيسية *@
<div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="card">
            <div class="card-body text-center">
                <div class="fs-3 fw-bold text-primary">@Model.TotalEnrollments</div>
                <div class="text-muted small">إجمالي التسجيلات</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card">
            <div class="card-body text-center">
                <div class="fs-3 fw-bold text-positive">@Model.CompletionRate%</div>
                <div class="text-muted small">نسبة الإتمام</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card">
            <div class="card-body text-center">
                <div class="fs-3 fw-bold" style="color: var(--clr-accent);">@Model.AverageProgress%</div>
                <div class="text-muted small">متوسط التقدم</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card">
            <div class="card-body text-center">
                <div class="fs-3 fw-bold text-primary">@Model.TotalCertificates</div>
                <div class="text-muted small">الشهادات الصادرة</div>
            </div>
        </div>
    </div>
</div>

@* إحصائيات ثانوية *@
<div class="row g-3 mb-4">
    <div class="col-md-4 col-sm-6">
        <div class="card">
            <div class="card-body text-center">
                <div class="fs-4 fw-bold">@Model.TotalCourses</div>
                <div class="text-muted small">إجمالي الدورات</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="card">
            <div class="card-body text-center">
                <div class="fs-4 fw-bold text-positive">@Model.PublishedCourses</div>
                <div class="text-muted small">الدورات المنشورة</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="card">
            <div class="card-body text-center">
                <div class="fs-4 fw-bold text-negative">@Model.CompletedEnrollments</div>
                <div class="text-muted small">التسجيلات المكتملة</div>
            </div>
        </div>
    </div>
</div>

@* إحصائيات لكل دورة *@
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-bar-chart-line me-2"></i>إحصائيات الدورات</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width: 30%;">الدورة</th>
                        <th>المسجلين</th>
                        <th>المكتملين</th>
                        <th>نسبة الإتمام</th>
                        <th>متوسط التقدم</th>
                        <th>الشهادات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.CourseStats.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">لا توجد دورات</td>
                        </tr>
                    }
                    @foreach (var course in Model.CourseStats)
                    {
                        <tr>
                            <td>
                                <a asp-action="Edit" asp-route-id="@course.CourseId" class="text-decoration-none fw-semibold">
                                    @course.CourseTitleAr
                                </a>
                            </td>
                            <td>@course.EnrollmentCount</td>
                            <td>@course.CompletedCount</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px; background-color: var(--card-border);">
                                        <div class="progress-bar bg-success" style="width: @course.CompletionRate%"></div>
                                    </div>
                                    <span class="small text-muted">@course.CompletionRate%</span>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px; background-color: var(--card-border);">
                                        <div class="progress-bar" style="width: @course.AverageProgress%; background-color: var(--clr-accent);"></div>
                                    </div>
                                    <span class="small text-muted">@course.AverageProgress%</span>
                                </div>
                            </td>
                            <td>@course.CertificateCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* آخر التسجيلات *@
<div class="card">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>آخر التسجيلات</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>المستخدم</th>
                        <th>البريد الإلكتروني</th>
                        <th>الدورة</th>
                        <th>التقدم</th>
                        <th>تاريخ التسجيل</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentEnrollments.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">لا توجد تسجيلات</td>
                        </tr>
                    }
                    @foreach (var enrollment in Model.RecentEnrollments)
                    {
                        <tr>
                            <td class="fw-semibold">@enrollment.UserDisplayName</td>
                            <td class="text-muted small" dir="ltr">@enrollment.UserEmail</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@enrollment.CourseId" class="text-decoration-none">
                                    @enrollment.CourseTitleAr
                                </a>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px; max-width: 100px; background-color: var(--card-border);">
                                        @if (enrollment.Progress >= 100)
                                        {
                                            <div class="progress-bar bg-success" style="width: 100%"></div>
                                        }
                                        else
                                        {
                                            <div class="progress-bar" style="width: @enrollment.Progress%; background-color: var(--clr-accent);"></div>
                                        }
                                    </div>
                                    <span class="small @(enrollment.Progress >= 100 ? "text-positive" : "text-muted")">@enrollment.Progress%</span>
                                </div>
                            </td>
                            <td>
                                <span class="text-muted small">@enrollment.EnrolledAt.ToString("yyyy/MM/dd HH:mm")</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
