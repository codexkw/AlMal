@model AlMal.Admin.ViewModels.SectorEditViewModel
@{
    ViewData["Title"] = "تعديل القطاع";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">تعديل القطاع: @Model.NameAr</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-3">
                        @* الاسم بالعربية *@
                        <div class="col-12">
                            <label asp-for="NameAr" class="form-label">الاسم بالعربية</label>
                            <input asp-for="NameAr" class="form-control" placeholder="مثال: البنوك" />
                            <span asp-validation-for="NameAr" class="text-danger small"></span>
                        </div>

                        @* الاسم بالإنجليزية *@
                        <div class="col-12">
                            <label asp-for="NameEn" class="form-label">الاسم بالإنجليزية</label>
                            <input asp-for="NameEn" class="form-control" dir="ltr" placeholder="e.g. Banks" />
                            <span asp-validation-for="NameEn" class="text-danger small"></span>
                        </div>

                        @* الحالة *@
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                                <label asp-for="IsActive" class="form-check-label">مفعّل</label>
                            </div>
                        </div>
                    </div>

                    @* أزرار الإجراءات *@
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>حفظ
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
