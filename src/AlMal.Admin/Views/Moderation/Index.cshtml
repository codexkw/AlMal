@model AlMal.Admin.ViewModels.ModerationQueueViewModel
@{
    ViewData["Title"] = "الإشراف على المحتوى";
}

@* ملخص المنشورات المبلّغ عنها *@
<div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
    <div>
        <span class="text-muted">إجمالي المنشورات المبلّغ عنها: @Model.TotalCount</span>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="BadgeRequests" class="btn btn-outline-info btn-sm">
            <i class="bi bi-patch-check me-1"></i>طلبات الشارات
        </a>
        <a asp-action="Users" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-people me-1"></i>إدارة المستخدمين
        </a>
    </div>
</div>

@* Success/Error alerts *@
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* جدول المنشورات المبلّغ عنها *@
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width: 5%;">#</th>
                        <th style="width: 10%;">النوع</th>
                        <th style="width: 25%;">المحتوى</th>
                        <th style="width: 12%;">المستخدم</th>
                        <th style="width: 13%;">سبب البلاغ</th>
                        <th style="width: 12%;">التاريخ</th>
                        <th style="width: 23%;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="bi bi-check-circle fs-3 d-block mb-2"></i>
                                لا توجد منشورات مبلّغ عنها
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>
                                <span class="badge bg-warning text-dark">@item.Type</span>
                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                {
                                    <i class="bi bi-image text-muted ms-1" title="يحتوي صورة"></i>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.VideoUrl))
                                {
                                    <i class="bi bi-camera-video text-muted ms-1" title="يحتوي فيديو"></i>
                                }
                            </td>
                            <td>
                                <div style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @item.Content
                                </div>
                            </td>
                            <td>
                                <span class="small">@item.UserDisplayName</span>
                            </td>
                            <td>
                                <span class="small text-muted">@(item.ReportReason ?? "—")</span>
                                @if (!string.IsNullOrEmpty(item.ReportedByDisplayName))
                                {
                                    <div class="small text-muted">بواسطة: @item.ReportedByDisplayName</div>
                                }
                            </td>
                            <td>
                                <span class="text-muted small">@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Review" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-info" title="مراجعة">
                                        <i class="bi bi-eye me-1"></i>مراجعة
                                    </a>
                                    <form asp-action="Approve" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="postId" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="موافقة">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    </form>
                                    <form asp-action="Delete" method="post" class="d-inline"
                                          onsubmit="return confirm('هل أنت متأكد من حذف هذا المنشور؟');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="postId" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="حذف">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ترقيم الصفحات *@
@if (Model.TotalPages > 1)
{
    <nav aria-label="ترقيم الصفحات" class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(Model.Page - 1)">
                    السابق
                </a>
            </li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i">
                        @i
                    </a>
                </li>
            }
            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(Model.Page + 1)">
                    التالي
                </a>
            </li>
        </ul>
    </nav>
}
