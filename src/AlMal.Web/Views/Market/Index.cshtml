<!-- ======================================================================
     6. SCRIPTS SECTION — SignalR, Quick Search, Price Updates
     ====================================================================== -->
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-chart-treemap@2.3.0/dist/chartjs-chart-treemap.min.js"></script>
    <script>
        // ----------------------------------------------------------------
        // Market Heatmap (Chart.js Treemap)
        // ----------------------------------------------------------------
        (function initHeatmap() {
            var stocks = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((Model.AllStocks ?? new List<AlMal.Web.ViewModels.Market.StockViewModel>())
                .Concat(Model.TopGainers ?? new List<AlMal.Web.ViewModels.Market.StockViewModel>())
                .Concat(Model.TopLosers ?? new List<AlMal.Web.ViewModels.Market.StockViewModel>())
                .GroupBy(s => s.Symbol).Select(g => g.First())
                .Select(s => new { s.Symbol, s.NameAr, change = s.DayChangePercent ?? 0, cap = s.MarketCap ?? 1 })));

            var placeholder = document.getElementById('heatmapPlaceholder');
            var canvas = document.getElementById('marketHeatmap');

            if (!stocks || stocks.length === 0) {
                if (placeholder) {
                    placeholder.innerHTML = '<i class="bi bi-grid-fill display-1 text-muted opacity-25"></i>' +
                        '<p class="text-muted mt-3 mb-0">لا توجد بيانات متاحة للخريطة الحرارية</p>';
                }
                return;
            }

            if (placeholder) placeholder.style.display = 'none';
            if (canvas) canvas.style.display = 'block';

            function getColor(change) {
                if (change > 3) return 'rgba(22, 163, 74, 0.9)';
                if (change > 1) return 'rgba(34, 197, 94, 0.8)';
                if (change > 0) return 'rgba(134, 239, 172, 0.7)';
                if (change === 0) return 'rgba(156, 163, 175, 0.5)';
                if (change > -1) return 'rgba(252, 165, 165, 0.7)';
                if (change > -3) return 'rgba(239, 68, 68, 0.8)';
                return 'rgba(185, 28, 28, 0.9)';
            }

            var ctx = canvas.getContext('2d');
            new Chart(ctx, {
                type: 'treemap',
                data: {
                    datasets: [{
                        tree: stocks,
                        key: 'cap',
                        groups: ['Symbol'],
                        backgroundColor: function(c) {
                            if (!c || !c.raw || !c.raw._data) return '#9ca3af';
                            var ch = c.raw._data.change;
                            return (ch !== undefined && ch !== null) ? getColor(ch) : '#9ca3af';
                        },
                        borderColor: 'rgba(255,255,255,0.5)',
                        borderWidth: 1,
                        spacing: 1,
                        labels: {
                            display: true,
                            align: 'center',
                            position: 'middle',
                            color: '#fff',
                            font: { size: 11, weight: 'bold', family: "'IBM Plex Sans Arabic', sans-serif" },
                            formatter: function(c) {
                                if (!c || !c.raw || !c.raw._data) return '';
                                var d = c.raw._data;
                                if (d.change === undefined || d.change === null) return d.symbol || d.Symbol || '';
                                var sym = d.symbol || d.Symbol || '';
                                var ch = Number(d.change);
                                if (isNaN(ch)) return sym;
                                var sign = ch >= 0 ? '+' : '';
                                return [sym, sign + ch.toFixed(2) + '%'];
                            }
                        },
                        captions: { display: false }
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                title: function(items) {
                                    if (!items.length || !items[0].raw || !items[0].raw._data) return '';
                                    var d = items[0].raw._data;
                                    var sym = d.symbol || d.Symbol || '';
                                    var name = d.nameAr || d.NameAr || '';
                                    return sym + (name ? ' - ' + name : '');
                                },
                                label: function(item) {
                                    if (!item.raw || !item.raw._data) return '';
                                    var d = item.raw._data;
                                    var ch = Number(d.change);
                                    if (isNaN(ch)) return '';
                                    var sign = ch >= 0 ? '+' : '';
                                    return 'التغير: ' + sign + ch.toFixed(2) + '%';
                                }
                            }
                        }
                    }
                }
            });
        })();
    </script>
    <script>
        // ----------------------------------------------------------------
        // SignalR Market Hub Connection
        // ----------------------------------------------------------------
        (function () {
            'use strict';

            const connection = new signalR.HubConnectionBuilder()
                .withUrl('/hubs/market')
                .withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
                .configureLogging(signalR.LogLevel.Warning)
                .build();

            // Connection state management
            connection.onreconnecting(function (error) {
                console.warn('SignalR: Reconnecting...', error);
                showConnectionStatus('جاري إعادة الاتصال...', 'warning');
            });

            connection.onreconnected(function (connectionId) {
                console.info('SignalR: Reconnected.', connectionId);
                showConnectionStatus('تم إعادة الاتصال', 'success');
                hideConnectionStatus(2000);
            });

            connection.onclose(function (error) {
                console.error('SignalR: Connection closed.', error);
                showConnectionStatus('انقطع الاتصال. جاري المحاولة...', 'danger');
                setTimeout(startConnection, 5000);
            });

            // ----------------------------------------------------------------
            // Price Update Handler
            // ----------------------------------------------------------------
            connection.on('ReceivePriceUpdate', function (update) {
                if (!update || !update.symbol) return;

                var symbol = update.symbol;
                var price = parseFloat(update.price);
                var change = parseFloat(update.change);
                var changePercent = parseFloat(update.changePercent);

                var isPositive = changePercent >= 0;
                var changeClass = isPositive ? 'text-success' : 'text-danger';
                var changeIcon = isPositive ? 'bi-caret-up-fill' : 'bi-caret-down-fill';
                var flashClass = isPositive ? 'price-flash-up' : 'price-flash-down';

                // Update all price elements for this symbol
                var priceEls = document.querySelectorAll('[data-price="' + symbol + '"]');
                priceEls.forEach(function (el) {
                    var oldPrice = parseFloat(el.textContent);
                    el.textContent = price.toFixed(2);

                    // Flash animation
                    if (oldPrice !== price) {
                        el.classList.remove('price-flash-up', 'price-flash-down');
                        void el.offsetWidth; // Force reflow
                        el.classList.add(flashClass);
                    }
                });

                // Update change elements
                var changeEls = document.querySelectorAll('[data-change="' + symbol + '"]');
                changeEls.forEach(function (el) {
                    el.className = changeClass + ' fw-semibold';
                    el.innerHTML = '<i class="bi ' + changeIcon + '"></i> ' + change.toFixed(2);
                });

                // Update change percent elements
                var changePctEls = document.querySelectorAll('[data-change-percent="' + symbol + '"]');
                changePctEls.forEach(function (el) {
                    el.className = changeClass + ' fw-bold small';
                    el.innerHTML = '<i class="bi ' + changeIcon + '"></i> ' + changePercent.toFixed(2) + '%';
                });
            });

            // ----------------------------------------------------------------
            // Index Update Handler
            // ----------------------------------------------------------------
            connection.on('ReceiveIndexUpdate', function (update) {
                if (!update || !update.name) return;

                var ticker = document.getElementById('indicesTicker');
                if (!ticker) return;

                // Find and update the matching index in the ticker
                var items = ticker.querySelectorAll('.d-flex > div');
                items.forEach(function (item) {
                    var nameEl = item.querySelector('.fw-semibold.text-muted');
                    if (nameEl && nameEl.textContent.trim() === update.name) {
                        var valueEl = item.querySelector('.fw-bold:not(.small)');
                        var changeEl = item.querySelector('.small.fw-semibold');

                        if (valueEl) {
                            valueEl.textContent = parseFloat(update.value).toFixed(2);
                        }
                        if (changeEl) {
                            var isPositive = parseFloat(update.change) >= 0;
                            changeEl.className = (isPositive ? 'text-success' : 'text-danger') + ' small fw-semibold';
                            changeEl.innerHTML =
                                '<i class="bi ' + (isPositive ? 'bi-caret-up-fill' : 'bi-caret-down-fill') + '"></i> ' +
                                parseFloat(update.change).toFixed(2) +
                                ' (' + parseFloat(update.changePercent).toFixed(2) + '%)';
                        }
                    }
                });
            });

            // ----------------------------------------------------------------
            // Quick Search AJAX Handler
            // ----------------------------------------------------------------
            function setupQuickSearch(inputId, resultsId) {
                var input = document.getElementById(inputId);
                var results = document.getElementById(resultsId);
                if (!input || !results) return;

                var debounceTimer;

                input.addEventListener('input', function () {
                    var query = this.value.trim();

                    clearTimeout(debounceTimer);

                    if (query.length < 1) {
                        results.innerHTML = '';
                        return;
                    }

                    debounceTimer = setTimeout(function () {
                        fetch('@Url.Action("QuickSearch", "Market")?query=' + encodeURIComponent(query), {
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        })
                        .then(function (response) {
                            if (!response.ok) throw new Error('Search request failed');
                            return response.json();
                        })
                        .then(function (data) {
                            if (!data || data.length === 0) {
                                results.innerHTML =
                                    '<div class="text-center text-muted py-4">' +
                                    '<i class="bi bi-search display-6 d-block mb-2 opacity-25"></i>' +
                                    'لا توجد نتائج لـ "' + escapeHtml(query) + '"' +
                                    '</div>';
                                return;
                            }

                            var html = '<div class="list-group list-group-flush">';
                            data.forEach(function (stock) {
                                var isPositive = stock.changePercent >= 0;
                                var changeClass = isPositive ? 'text-success' : 'text-danger';
                                var changeIcon = isPositive ? 'bi-caret-up-fill' : 'bi-caret-down-fill';

                                html +=
                                    '<a href="/stock/' + encodeURIComponent(stock.symbol) + '"' +
                                    '   class="list-group-item list-group-item-action d-flex align-items-center justify-content-between py-2 px-3">' +
                                    '  <div>' +
                                    '    <span class="fw-bold" style="color: #4F0E5E;">' + escapeHtml(stock.symbol) + '</span>' +
                                    '    <br/><span class="text-muted small">' + escapeHtml(stock.companyName) + '</span>' +
                                    '  </div>' +
                                    '  <div class="text-end">' +
                                    '    <span class="fw-semibold">' + parseFloat(stock.price).toFixed(2) + '</span>' +
                                    '    <br/><span class="' + changeClass + ' fw-bold small">' +
                                    '      <i class="bi ' + changeIcon + '"></i> ' +
                                    parseFloat(stock.changePercent).toFixed(2) + '%' +
                                    '    </span>' +
                                    '  </div>' +
                                    '</a>';
                            });
                            html += '</div>';
                            results.innerHTML = html;
                        })
                        .catch(function (error) {
                            console.error('Quick search error:', error);
                            results.innerHTML =
                                '<div class="text-center text-danger py-3">' +
                                '<i class="bi bi-exclamation-triangle me-1"></i>' +
                                'حدث خطأ أثناء البحث' +
                                '</div>';
                        });
                    }, 300);
                });
            }

            // Initialize quick search for both mobile and desktop
            setupQuickSearch('quickSearchInput', 'quickSearchResults');
            setupQuickSearch('desktopQuickSearchInput', 'desktopQuickSearchResults');

            // ----------------------------------------------------------------
            // Connection Status UI
            // ----------------------------------------------------------------
            function showConnectionStatus(message, type) {
                var el = document.getElementById('connectionStatus');
                if (!el) {
                    el = document.createElement('div');
                    el.id = 'connectionStatus';
                    el.className = 'position-fixed bottom-0 start-50 translate-middle-x mb-3 px-4 py-2 rounded-pill shadow-lg text-white small fw-semibold';
                    el.style.zIndex = '1090';
                    el.style.transition = 'opacity 0.3s ease';
                    document.body.appendChild(el);
                }

                var bgColors = {
                    'success': '#198754',
                    'warning': '#fd7e14',
                    'danger': '#dc3545'
                };

                el.style.backgroundColor = bgColors[type] || '#6c757d';
                el.textContent = message;
                el.style.opacity = '1';
                el.style.display = 'block';
            }

            function hideConnectionStatus(delay) {
                setTimeout(function () {
                    var el = document.getElementById('connectionStatus');
                    if (el) {
                        el.style.opacity = '0';
                        setTimeout(function () {
                            el.style.display = 'none';
                        }, 300);
                    }
                }, delay || 0);
            }

            // ----------------------------------------------------------------
            // Utility: Escape HTML
            // ----------------------------------------------------------------
            function escapeHtml(text) {
                var div = document.createElement('div');
                div.appendChild(document.createTextNode(text));
                return div.innerHTML;
            }

            // ----------------------------------------------------------------
            // Start Connection
            // ----------------------------------------------------------------
            function startConnection() {
                connection.start()
                    .then(function () {
                        console.info('SignalR: Connected to /hubs/market');
                    })
                    .catch(function (err) {
                        console.error('SignalR: Connection failed.', err);
                        setTimeout(startConnection, 5000);
                    });
            }

            // Keyboard shortcut: Ctrl+K / Cmd+K to open search
            document.addEventListener('keydown', function (e) {
                if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                    e.preventDefault();
                    var modal = document.getElementById('desktopSearchModal');
                    if (modal && window.innerWidth >= 992) {
                        var bsModal = bootstrap.Modal.getOrCreateInstance(modal);
                        bsModal.toggle();
                    }
                }
            });

            // Start the SignalR connection
            startConnection();
        })();

        // ----------------------------------------------------------------
        // Watchlist Search Modal (Alpine.js component)
        // ----------------------------------------------------------------
        function watchlistSearch() {
            return {
                query: '',
                results: [],
                loading: false,
                async search() {
                    if (this.query.length < 1) { this.results = []; return; }
                    this.loading = true;
                    try {
                        var response = await fetch('/Market/Search?q=' + encodeURIComponent(this.query));
                        var data = await response.json();
                        this.results = data.map(function(s) {
                            return { symbol: s.symbol, nameAr: s.nameAr, stockId: s.id, added: false, loading: false };
                        });
                    } catch (e) {
                        console.error('Search error:', e);
                    } finally {
                        this.loading = false;
                    }
                },
                async toggleWatchlist(stock) {
                    stock.loading = true;
                    try {
                        var token = document.querySelector('input[name="__RequestVerificationToken"]');
                        var formData = new FormData();
                        formData.append('stockId', stock.stockId);
                        if (token) formData.append('__RequestVerificationToken', token.value);
                        var response = await fetch('/Watchlist/Toggle?stockId=' + stock.stockId, {
                            method: 'POST',
                            headers: token ? { 'RequestVerificationToken': token.value } : {},
                            body: formData
                        });
                        var result = await response.json();
                        if (result.success) {
                            stock.added = result.added;
                            // Refresh the watchlist tab content
                            var wlEl = document.getElementById('watchlistContent');
                            if (wlEl && typeof htmx !== 'undefined') {
                                htmx.ajax('GET', wlEl.getAttribute('hx-get'), { target: '#watchlistContent', swap: 'innerHTML' });
                            }
                        }
                    } catch (e) {
                        console.error('Toggle watchlist error:', e);
                    } finally {
                        stock.loading = false;
                    }
                }
            };
        }
    </script>
}
