@model List<AlMal.Web.ViewModels.Market.SectorViewModel>

@if (Model == null || Model.Count == 0)
{
    <div class="text-center py-5">
        <i class="bi bi-pie-chart fs-1 text-muted"></i>
        <p class="text-muted mt-2 mb-0">لا توجد قطاعات متاحة حالياً</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var sector in Model)
        {
            var changeClass = sector.ChangePercent >= 0 ? "text-success" : "text-danger";
            var changeIcon = sector.ChangePercent >= 0 ? "bi-caret-up-fill" : "bi-caret-down-fill";
            <div class="col-12 col-sm-6 col-lg-4">
                <a asp-controller="Market" asp-action="Index" asp-route-sector="@sector.Id"
                   class="card border-0 shadow-sm text-decoration-none h-100" style="transition: transform 0.15s;">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="fw-bold mb-0" style="color: #4F0E5E;">@sector.NameAr</h6>
                            <span class="badge bg-light text-muted">@sector.StockCount سهم</span>
                        </div>
                        @if (sector.IndexValue.HasValue)
                        {
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-semibold">@sector.IndexValue?.ToString("N2")</span>
                                @if (sector.ChangePercent.HasValue)
                                {
                                    <span class="@changeClass small fw-bold">
                                        <i class="bi @changeIcon"></i>
                                        @sector.ChangePercent?.ToString("N2")%
                                    </span>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="text-muted small">لا توجد بيانات</span>
                        }
                    </div>
                </a>
            </div>
        }
    </div>
}
