@model AlMal.Web.ViewModels.Alert.AlertListViewModel
@{
    ViewData["Title"] = "التنبيهات";
}

<div class="container-fluid px-lg-4 py-3">

    @* ===== PAGE HEADER ===== *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">
                <i class="bi bi-bell-fill ms-2" style="color: var(--clr-accent)"></i>التنبيهات
            </h1>
            <p class="text-muted mb-0">إدارة تنبيهات أسعار الأسهم والإفصاحات</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill" style="background-color: var(--clr-primary); border-color: var(--clr-primary);">
            <i class="bi bi-plus-lg ms-1"></i>تنبيه جديد
        </a>
    </div>

    @* ===== SUCCESS MESSAGE ===== *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle ms-1"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="إغلاق"></button>
        </div>
    }

    @if (Model.Alerts.Count == 0)
    {
        @* ===== EMPTY STATE ===== *@
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="bi bi-bell display-1 text-muted"></i>
            </div>
            <h4 class="text-muted mb-3">لا توجد تنبيهات</h4>
            <p class="text-muted mb-4">أنشئ تنبيهات لمتابعة أسعار الأسهم والإفصاحات وتحركات المؤشرات</p>
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4" style="background-color: var(--clr-primary); border-color: var(--clr-primary);">
                <i class="bi bi-plus-lg ms-1"></i>إنشاء أول تنبيه
            </a>
        </div>
    }
    else
    {
        @* ===== ALERT LIST ===== *@
        <div class="row g-3">
            @foreach (var alert in Model.Alerts)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100 @(alert.IsActive ? "" : "opacity-50")">
                        <div class="card-body p-3">
                            @* Type Badge + Status *@
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge rounded-pill" style="background-color: var(--clr-primary);">
                                        <i class="bi @alert.TypeIcon ms-1"></i>@alert.TypeDisplay
                                    </span>
                                    @if (alert.IsActive)
                                    {
                                        <span class="badge bg-success rounded-pill">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill">متوقف</span>
                                    }
                                </div>
                                <span class="badge bg-dark bg-opacity-10 text-dark small">
                                    <i class="bi bi-broadcast ms-1"></i>@alert.ChannelDisplay
                                </span>
                            </div>

                            @* Stock Info *@
                            @if (!string.IsNullOrEmpty(alert.StockNameAr))
                            {
                                <h6 class="fw-bold mb-1">@alert.StockNameAr</h6>
                                <span class="badge bg-dark bg-opacity-10 text-dark small mb-2">@alert.StockSymbol</span>
                            }

                            @* Condition & Target *@
                            @if (alert.TargetValue.HasValue)
                            {
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="text-muted small">@alert.ConditionDisplay</span>
                                    <span class="fw-bold" style="color: var(--clr-accent);">
                                        @alert.TargetValue.Value.ToString("N3") د.ك
                                    </span>
                                </div>
                            }

                            @* Last Triggered *@
                            @if (alert.LastTriggered.HasValue)
                            {
                                <div class="text-muted small mb-2">
                                    <i class="bi bi-clock-history ms-1"></i>
                                    آخر تفعيل: @alert.LastTriggered.Value.ToString("yyyy/MM/dd HH:mm")
                                </div>
                            }

                            @* Actions *@
                            <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
                                <form asp-action="Toggle" asp-route-id="@alert.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm @(alert.IsActive ? "btn-outline-warning" : "btn-outline-success") rounded-pill">
                                        @if (alert.IsActive)
                                        {
                                            <i class="bi bi-pause-fill ms-1"></i><span>إيقاف</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-play-fill ms-1"></i><span>تفعيل</span>
                                        }
                                    </button>
                                </form>
                                <form asp-action="Delete" asp-route-id="@alert.Id" method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('هل أنت متأكد من حذف هذا التنبيه؟')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">
                                        <i class="bi bi-trash ms-1"></i>حذف
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
