@model AlMal.Web.ViewModels.Community.CommentViewModel
@using AlMal.Domain.Enums
@{
    var initials = "";
    if (!string.IsNullOrWhiteSpace(Model.UserDisplayName))
    {
        var parts = Model.UserDisplayName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        initials = parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : Model.UserDisplayName[..Math.Min(2, Model.UserDisplayName.Length)];
    }

    var timeAgo = "";
    var diff = DateTime.UtcNow - Model.CreatedAt;
    if (diff.TotalMinutes < 1)
        timeAgo = "الآن";
    else if (diff.TotalMinutes < 60)
        timeAgo = $"منذ {(int)diff.TotalMinutes} دقيقة";
    else if (diff.TotalHours < 24)
        timeAgo = $"منذ {(int)diff.TotalHours} ساعة";
    else if (diff.TotalDays < 30)
        timeAgo = $"منذ {(int)diff.TotalDays} يوم";
    else if (diff.TotalDays < 365)
        timeAgo = $"منذ {(int)(diff.TotalDays / 30)} شهر";
    else
        timeAgo = $"منذ {(int)(diff.TotalDays / 365)} سنة";

    var isReply = Model.ParentCommentId.HasValue;
}

<div class="d-flex align-items-start gap-2 @(isReply ? "ms-4" : "") mb-2 py-1">
    @* Comment Avatar *@
    <a asp-controller="Profile" asp-action="Index" asp-route-id="@Model.UserId" class="text-decoration-none flex-shrink-0">
        @if (!string.IsNullOrWhiteSpace(Model.UserAvatarUrl))
        {
            <img src="@Model.UserAvatarUrl"
                 alt="@Model.UserDisplayName"
                 class="rounded-circle"
                 width="32" height="32"
                 style="object-fit: cover; border: 1px solid var(--card-border);" />
        }
        else
        {
            <div class="rounded-circle d-inline-flex align-items-center justify-content-center"
                 style="width: 32px; height: 32px; background-color: var(--clr-primary); color: #fff; font-weight: 700; font-size: 0.65rem; border: 1px solid var(--card-border);">
                @initials
            </div>
        }
    </a>

    @* Comment Body *@
    <div class="flex-grow-1" style="min-width: 0;">
        <div class="rounded p-2" style="background-color: var(--hover-bg);">
            <div class="d-flex align-items-center flex-wrap gap-1 mb-1">
                <a asp-controller="Profile" asp-action="Index" asp-route-id="@Model.UserId"
                   class="fw-bold small text-body text-decoration-none">
                    @Model.UserDisplayName
                </a>
                @if (Model.UserType == UserType.ProAnalyst)
                {
                    <span class="badge bg-warning text-dark" style="font-size: 0.6rem; padding: 0.15em 0.4em;"><i class="bi bi-star-fill me-1"></i>محلل متميز</span>
                }
                else if (Model.UserType == UserType.CertifiedAnalyst)
                {
                    <span class="badge" style="background-color: var(--clr-primary); font-size: 0.6rem; padding: 0.15em 0.4em;"><i class="bi bi-patch-check-fill me-1"></i>محلل معتمد</span>
                }
            </div>
            <div class="small" style="white-space: pre-wrap; word-break: break-word;">@Model.Content</div>
        </div>
        <div class="text-muted small mt-1" style="font-size: 0.7rem;">@timeAgo</div>
    </div>
</div>

@* Render replies if any *@
@if (Model.Replies.Count > 0)
{
    foreach (var reply in Model.Replies)
    {
        @await Html.PartialAsync("_Comment", reply)
    }
}
