@model AlMal.Web.ViewModels.News.NewsFeedViewModel

@functions {
    static string TimeAgoAr(DateTime publishedAt)
    {
        var diff = DateTime.UtcNow - publishedAt;

        if (diff.TotalMinutes < 1)
            return "الآن";
        if (diff.TotalMinutes < 60)
            return $"منذ {(int)diff.TotalMinutes} دقيقة";
        if (diff.TotalHours < 24)
            return $"منذ {(int)diff.TotalHours} ساعة";
        if (diff.TotalDays < 30)
            return $"منذ {(int)diff.TotalDays} يوم";
        if (diff.TotalDays < 365)
            return $"منذ {(int)(diff.TotalDays / 30)} شهر";

        return $"منذ {(int)(diff.TotalDays / 365)} سنة";
    }

    static string SentimentTextAr(AlMal.Domain.Enums.Sentiment sentiment)
    {
        return sentiment switch
        {
            AlMal.Domain.Enums.Sentiment.Positive => "إيجابي",
            AlMal.Domain.Enums.Sentiment.Negative => "سلبي",
            _ => "محايد"
        };
    }

    static string SentimentBadgeClass(AlMal.Domain.Enums.Sentiment sentiment)
    {
        return sentiment switch
        {
            AlMal.Domain.Enums.Sentiment.Positive => "bg-success",
            AlMal.Domain.Enums.Sentiment.Negative => "bg-danger",
            _ => "bg-secondary"
        };
    }
}

@foreach (var article in Model.Articles)
{
    var badgeClass = SentimentBadgeClass(article.Sentiment);
    var sentimentText = SentimentTextAr(article.Sentiment);
    var timeAgo = TimeAgoAr(article.PublishedAt);

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            @* Header: Source + Sentiment + Time *@
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge bg-dark bg-opacity-10 text-dark">@article.Source</span>
                <span class="badge @badgeClass">@sentimentText</span>
                <small class="text-muted ms-auto">@timeAgo</small>
            </div>

            @* Title *@
            <h6 class="fw-bold mb-2">@article.TitleAr</h6>

            @* Summary *@
            @if (!string.IsNullOrWhiteSpace(article.Summary))
            {
                var truncated = article.Summary.Length > 200
                    ? article.Summary.Substring(0, 200) + "..."
                    : article.Summary;
                <p class="text-muted small mb-2">@truncated</p>
            }

            @* Related stock tags *@
            @if (article.RelatedStocks.Any())
            {
                <div class="d-flex flex-wrap gap-1 mb-2">
                    @foreach (var stock in article.RelatedStocks)
                    {
                        <a asp-controller="Stock" asp-action="Detail" asp-route-symbol="@stock.Symbol"
                           class="badge bg-primary bg-opacity-10 text-primary text-decoration-none">
                            @stock.Symbol
                        </a>
                    }
                </div>
            }

            @* Source link *@
            @if (!string.IsNullOrWhiteSpace(article.SourceUrl))
            {
                <a href="@article.SourceUrl"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="btn btn-sm btn-outline-secondary rounded-pill">
                    المصدر <i class="bi bi-box-arrow-up-left"></i>
                </a>
            }
        </div>
    </div>
}

@* HTMX Load More trigger for next page *@
@if (Model.Page < Model.TotalPages)
{
    var nextPage = Model.Page + 1;
    var feedUrl = Url.Action("Feed", "News", new
    {
        stock = Model.StockFilter,
        sector = Model.SectorFilter,
        sentiment = Model.SentimentFilter,
        page = nextPage
    });
    <div id="load-more-trigger"
         hx-get="@feedUrl"
         hx-trigger="revealed"
         hx-target="closest div"
         hx-swap="outerHTML"
         class="text-center py-3">
        <div class="spinner-border spinner-border-sm text-primary" role="status">
            <span class="visually-hidden">جاري التحميل...</span>
        </div>
        <span class="text-muted small me-2">جاري تحميل المزيد...</span>
    </div>
}
