<!DOCTYPE html>
<html dir="rtl" lang="ar" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - قناة المال</title>

    <!-- Google Fonts: IBM Plex Sans Arabic + IBM Plex Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5.3 RTL -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
          integrity="sha384-dpuaG1suU0eT09tx5plTaGMLBsfDLzUCCUXOY2v/bp+21CWDS4ZEBdmsBgHwMYGn"
          crossorigin="anonymous" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AlMal.Web.styles.css" asp-append-version="true" />

    <!-- HTMX -->
    <script src="https://unpkg.com/htmx.org@1.9.12"></script>

    <!-- AlpineJS -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Top Navbar -->
    <header>
        <nav class="navbar navbar-expand-md navbar-dark almal-navbar" x-data="{ mobileOpen: false }">
            <div class="container-fluid">
                <!-- Brand -->
                <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
                    قناة المال
                </a>

                <!-- Hamburger Toggle (mobile) -->
                <button class="navbar-toggler border-0"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="القائمة">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Collapsible Nav Links -->
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-md-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-graph-up-arrow ms-1"></i>السوق
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="News" asp-action="Index">
                                <i class="bi bi-newspaper ms-1"></i>الأخبار
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Community" asp-action="Index">
                                <i class="bi bi-people ms-1"></i>المجتمع
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Academy" asp-action="Index">
                                <i class="bi bi-book ms-1"></i>الأكاديمية
                            </a>
                        </li>
                    </ul>

                    <!-- Right side: theme toggle + profile -->
                    <ul class="navbar-nav ms-auto mb-2 mb-md-0 align-items-center">
                        <!-- Dark/Light Mode Toggle -->
                        <li class="nav-item" x-data="themeToggle()">
                            <button class="btn btn-link nav-link px-2" type="button"
                                    @@click="toggle()" :title="isDark ? 'الوضع الفاتح' : 'الوضع الداكن'">
                                <i class="bi" :class="isDark ? 'bi-sun-fill' : 'bi-moon-fill'"></i>
                            </button>
                        </li>

                        <!-- Profile / Login -->
                        <li class="nav-item">
                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                <a class="nav-link" asp-controller="Account" asp-action="Profile">
                                    <i class="bi bi-person-circle ms-1"></i>حسابي
                                </a>
                            }
                            else
                            {
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-left ms-1"></i>تسجيل الدخول
                                </a>
                            }
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <div class="container-fluid px-md-4">
        <main role="main" class="pb-5 mb-5 mb-md-0 pt-3">
            @RenderBody()
        </main>
    </div>

    <!-- Bottom Nav Bar (mobile only) - rendered as a view component -->
    @await Html.PartialAsync("Components/BottomNavBar/_Default")

    <!-- Footer (hidden on mobile where bottom nav shows) -->
    <footer class="almal-footer d-none d-md-block text-center py-3 mt-4">
        <div class="container">
            <span>&copy; 2026 قناة المال</span>
        </div>
    </footer>

    <!-- Bootstrap Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>

    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <!-- Site JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
