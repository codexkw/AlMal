@*
    Loading Skeleton Partial

    Usage: @await Html.PartialAsync("_LoadingSkeleton", null, new ViewDataDictionary(ViewData) {
        { "SkeletonType", "card" },   // card | list | chart | text
        { "SkeletonCount", 3 }        // number of skeleton items
    })

    SkeletonType options:
        "card"  - Card-shaped skeleton (default)
        "list"  - List rows skeleton
        "chart" - Chart placeholder skeleton
        "text"  - Text lines skeleton

    SkeletonCount: number of repeated items (default: 3)
*@

@{
    var skeletonType = ViewData["SkeletonType"]?.ToString() ?? "card";
    var skeletonCount = ViewData["SkeletonCount"] != null ? Convert.ToInt32(ViewData["SkeletonCount"]) : 3;
}

@if (skeletonType == "card")
{
    <div class="row g-3">
        @for (int i = 0; i < skeletonCount; i++)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card">
                    <div class="card-body">
                        <div class="skeleton skeleton-title"></div>
                        <div class="skeleton skeleton-text" style="width: 80%;"></div>
                        <div class="skeleton skeleton-text" style="width: 60%;"></div>
                        <div class="skeleton skeleton-text-sm" style="width: 40%;"></div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (skeletonType == "list")
{
    <div class="list-group">
        @for (int i = 0; i < skeletonCount; i++)
        {
            <div class="list-group-item d-flex align-items-center gap-3 border-0" style="background: transparent;">
                <div class="skeleton skeleton-avatar"></div>
                <div class="flex-grow-1">
                    <div class="skeleton skeleton-text" style="width: 50%;"></div>
                    <div class="skeleton skeleton-text-sm" style="width: 30%;"></div>
                </div>
                <div class="skeleton skeleton-text-sm" style="width: 60px;"></div>
            </div>
        }
    </div>
}
else if (skeletonType == "chart")
{
    <div class="skeleton skeleton-chart w-100 mb-3"></div>
    <div class="d-flex gap-2">
        <div class="skeleton skeleton-text" style="width: 80px;"></div>
        <div class="skeleton skeleton-text" style="width: 80px;"></div>
        <div class="skeleton skeleton-text" style="width: 80px;"></div>
    </div>
}
else if (skeletonType == "text")
{
    @for (int i = 0; i < skeletonCount; i++)
    {
        <div class="skeleton skeleton-text" style="width: @(90 - (i * 10))%;"></div>
    }
    <div class="skeleton skeleton-text-sm" style="width: 40%;"></div>
}
