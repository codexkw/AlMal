@model AlMal.Web.ViewModels.Academy.MyCertificatesViewModel
@{
    ViewData["Title"] = "شهاداتي";
}

@* ── Breadcrumb ── *@
<nav aria-label="مسار التنقل" class="mb-3">
    <ol class="breadcrumb small">
        <li class="breadcrumb-item"><a asp-action="Index">الأكاديمية</a></li>
        <li class="breadcrumb-item active" aria-current="page">شهاداتي</li>
    </ol>
</nav>

@* ── Page Header ── *@
<section class="mb-4">
    <h1 class="h3 fw-bold">
        <i class="bi bi-award ms-2"></i>شهاداتي
    </h1>
    <p class="text-muted">جميع الشهادات التي حصلت عليها من أكاديمية قناة المال</p>
</section>

@* ── Certificates Grid ── *@
@if (Model.Certificates.Count > 0)
{
    <div class="row g-3">
        @foreach (var cert in Model.Certificates)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100" style="background: var(--card-bg); border: 1px solid var(--card-border) !important;">
                    <div class="card-body p-4 text-center">
                        <div class="mb-3" style="color: var(--clr-accent);">
                            <i class="bi bi-award-fill" style="font-size: 3rem;"></i>
                        </div>

                        <h5 class="fw-bold mb-2">@cert.CourseTitleAr</h5>

                        <div class="text-muted small mb-3">
                            <div class="mb-1">
                                <i class="bi bi-calendar ms-1"></i>
                                @cert.CompletionDate.ToString("yyyy/MM/dd")
                            </div>
                            <div style="font-family: var(--font-mono); direction: ltr;">
                                @cert.CertificateNumber
                            </div>
                        </div>

                        <a asp-action="Certificate" asp-route-id="@cert.Id" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-eye ms-1"></i>عرض الشهادة
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", (object?)null, new ViewDataDictionary(ViewData) {
        { "EmptyIcon", "bi-award" },
        { "EmptyTitle", "لا توجد شهادات بعد" },
        { "EmptyMessage", "أكمل دورة تدريبية للحصول على شهادة" },
        { "EmptyActionUrl", Url.Action("Index", "Academy") },
        { "EmptyActionText", "تصفح الدورات" }
    })
}
