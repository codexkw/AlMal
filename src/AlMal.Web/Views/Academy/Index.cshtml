@model AlMal.Web.ViewModels.Academy.CourseCatalogViewModel
@{
    ViewData["Title"] = "الأكاديمية";
}

@* ── Page Header ── *@
<section class="mb-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
            <h1 class="h3 fw-bold mb-1">
                <i class="bi bi-book ms-2"></i>الأكاديمية
            </h1>
            <p class="text-muted mb-0">تعلّم أساسيات الاستثمار والتحليل المالي</p>
        </div>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <a asp-action="MyCertificates" class="btn btn-outline-light btn-sm">
                <i class="bi bi-award ms-1"></i>شهاداتي
            </a>
        }
    </div>
</section>

@* ── Difficulty Filter ── *@
<section class="mb-4">
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Index"
           class="btn btn-sm @(string.IsNullOrEmpty(Model.DifficultyFilter) ? "btn-primary" : "btn-outline-secondary")">
            الكل
        </a>
        <a asp-action="Index" asp-route-difficulty="free"
           class="btn btn-sm @(Model.DifficultyFilter == "free" ? "btn-primary" : "btn-outline-secondary")">
            <i class="bi bi-unlock ms-1"></i>مجاني
        </a>
        <a asp-action="Index" asp-route-difficulty="paid"
           class="btn btn-sm @(Model.DifficultyFilter == "paid" ? "btn-primary" : "btn-outline-secondary")">
            <i class="bi bi-lock ms-1"></i>مدفوع
        </a>
    </div>
</section>

@* ── Course Count ── *@
<div class="mb-3">
    <small class="text-muted">@Model.TotalCourses دورة متاحة</small>
</div>

@* ── Course Grid ── *@
@if (Model.Courses.Count > 0)
{
    <div class="row g-3">
        @foreach (var course in Model.Courses)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm" style="background: var(--card-bg); border: 1px solid var(--card-border) !important;">
                    @* Thumbnail *@
                    @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                    {
                        <img src="@course.ThumbnailUrl" class="card-img-top" alt="@course.TitleAr"
                             style="height: 180px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="card-img-top d-flex align-items-center justify-content-center"
                             style="height: 180px; background: linear-gradient(135deg, var(--clr-primary), var(--clr-accent));">
                            <i class="bi bi-book text-white" style="font-size: 3rem;"></i>
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        @* Badges *@
                        <div class="mb-2 d-flex gap-2">
                            @if (course.IsFree)
                            {
                                <span class="badge bg-success">مجاني</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@course.Price?.ToString("N3") د.ك</span>
                            }
                        </div>

                        @* Title & Description *@
                        <h5 class="card-title fw-bold mb-2">@course.TitleAr</h5>
                        @if (!string.IsNullOrEmpty(course.DescriptionAr))
                        {
                            <p class="card-text text-muted small mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @course.DescriptionAr
                            </p>
                        }

                        @* Stats *@
                        <div class="d-flex gap-3 text-muted small mb-3 mt-auto">
                            <span><i class="bi bi-collection ms-1"></i>@course.LessonCount درس</span>
                            @if (course.TotalDurationMinutes > 0)
                            {
                                <span><i class="bi bi-clock ms-1"></i>@course.TotalDurationMinutes د</span>
                            }
                            <span><i class="bi bi-people ms-1"></i>@course.EnrolledCount</span>
                        </div>

                        @* Progress bar for enrolled users *@
                        @if (course.IsEnrolled)
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="text-muted">التقدم</span>
                                    <span class="fw-semibold" style="color: var(--clr-positive);">@course.ProgressPercent%</span>
                                </div>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar" role="progressbar"
                                         style="width: @(course.ProgressPercent)%; background: var(--clr-positive);"
                                         aria-valuenow="@course.ProgressPercent" aria-valuemin="0" aria-valuemax="100">
                                    </div>
                                </div>
                            </div>
                        }

                        @* Action button *@
                        @if (course.IsEnrolled)
                        {
                            <a asp-action="Course" asp-route-id="@course.Id" class="btn btn-primary btn-sm w-100">
                                <i class="bi bi-play-circle ms-1"></i>متابعة التعلم
                            </a>
                        }
                        else
                        {
                            <a asp-action="Course" asp-route-id="@course.Id" class="btn btn-outline-primary btn-sm w-100">
                                <i class="bi bi-info-circle ms-1"></i>تفاصيل الدورة
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @* ── Pagination ── *@
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4" aria-label="التنقل بين الصفحات">
            <ul class="pagination justify-content-center">
                @if (Model.Page > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-difficulty="@Model.DifficultyFilter"
                           asp-route-page="@(Model.Page - 1)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-difficulty="@Model.DifficultyFilter"
                           asp-route-page="@i">@i</a>
                    </li>
                }

                @if (Model.Page < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-difficulty="@Model.DifficultyFilter"
                           asp-route-page="@(Model.Page + 1)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
}
else
{
    @* Empty state *@
    @await Html.PartialAsync("_EmptyState", (object?)null, new ViewDataDictionary(ViewData) {
        { "EmptyIcon", "bi-book" },
        { "EmptyTitle", "لا توجد دورات متاحة" },
        { "EmptyMessage", "ستتم إضافة دورات جديدة قريباً" }
    })
}
