@model AlMal.Web.ViewModels.Academy.LessonViewModel
@{
    ViewData["Title"] = Model.TitleAr;
}

@* ── Breadcrumb ── *@
<nav aria-label="مسار التنقل" class="mb-3">
    <ol class="breadcrumb small">
        <li class="breadcrumb-item"><a asp-action="Index">الأكاديمية</a></li>
        <li class="breadcrumb-item"><a asp-action="Course" asp-route-id="@Model.CourseId">@Model.CourseTitleAr</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.TitleAr</li>
    </ol>
</nav>

@* ── Lesson Header ── *@
<section class="mb-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
        <h1 class="h3 fw-bold mb-0">@Model.TitleAr</h1>
        @if (Model.IsCompleted)
        {
            <span class="badge bg-success fs-6">
                <i class="bi bi-check-circle ms-1"></i>مكتمل
            </span>
        }
    </div>
</section>

@* ── Video Player ── *@
@if (!string.IsNullOrEmpty(Model.VideoUrl))
{
    <section class="mb-4">
        <div class="ratio ratio-16x9 rounded overflow-hidden shadow-sm">
            @{
                var isYouTube = Model.VideoUrl.Contains("youtube.com") || Model.VideoUrl.Contains("youtu.be");
                var videoId = "";
                if (isYouTube)
                {
                    if (Model.VideoUrl.Contains("youtu.be/"))
                    {
                        videoId = Model.VideoUrl.Split("youtu.be/").Last().Split('?').First();
                    }
                    else if (Model.VideoUrl.Contains("v="))
                    {
                        videoId = Model.VideoUrl.Split("v=").Last().Split('&').First();
                    }
                }
            }
            @if (isYouTube)
            {
                <iframe src="https://www.youtube.com/embed/@videoId"
                        title="@Model.TitleAr"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen>
                </iframe>
            }
            else
            {
                @* Generic video *@
                <video controls class="w-100">
                    <source src="@Model.VideoUrl" />
                    المتصفح لا يدعم تشغيل الفيديو.
                </video>
            }
        </div>
    </section>
}

@* ── Lesson Content ── *@
@if (!string.IsNullOrEmpty(Model.ContentAr))
{
    <section class="mb-4">
        <div class="card border-0 shadow-sm" style="background: var(--card-bg); border: 1px solid var(--card-border) !important;">
            <div class="card-body p-4" style="line-height: 1.9; font-size: 1.05rem;">
                @Html.Raw(Model.ContentAr)
            </div>
        </div>
    </section>
}

@* ── Action Buttons ── *@
<section class="mb-4">
    <div class="d-flex flex-wrap gap-2 justify-content-center">
        @if (Model.HasQuiz)
        {
            @* Lesson has a quiz — primary action is to take the quiz *@
            <a asp-action="Quiz" asp-route-lessonId="@Model.Id" class="btn btn-primary btn-lg">
                <i class="bi bi-question-circle ms-1"></i>ابدأ الاختبار
            </a>
        }
        else if (!Model.IsCompleted)
        {
            @* No quiz — allow marking as complete *@
            <form asp-action="CompleteLesson" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="lessonId" value="@Model.Id" />
                <button type="submit" class="btn btn-success btn-lg">
                    <i class="bi bi-check-circle ms-1"></i>إكمال الدرس
                </button>
            </form>
        }
        else
        {
            <span class="btn btn-outline-success btn-lg disabled">
                <i class="bi bi-check-circle-fill ms-1"></i>تم إكمال هذا الدرس
            </span>
        }
    </div>
</section>

@* ── Previous / Next Navigation ── *@
<section class="mt-4">
    <div class="d-flex justify-content-between">
        @if (Model.PreviousLessonId.HasValue)
        {
            <a asp-action="Lesson" asp-route-id="@Model.PreviousLessonId" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-right ms-1"></i>الدرس السابق
            </a>
        }
        else
        {
            <div></div>
        }

        <a asp-action="Course" asp-route-id="@Model.CourseId" class="btn btn-outline-secondary">
            <i class="bi bi-list-ul ms-1"></i>قائمة الدروس
        </a>

        @if (Model.NextLessonId.HasValue)
        {
            <a asp-action="Lesson" asp-route-id="@Model.NextLessonId" class="btn btn-outline-secondary">
                الدرس التالي<i class="bi bi-arrow-left me-1"></i>
            </a>
        }
        else
        {
            <div></div>
        }
    </div>
</section>
