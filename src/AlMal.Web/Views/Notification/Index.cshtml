@model AlMal.Web.ViewModels.Notification.NotificationListViewModel
@{
    ViewData["Title"] = "الإشعارات";
}

<div class="container-fluid px-lg-4 py-3">

    @* ===== PAGE HEADER ===== *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">
                <i class="bi bi-bell ms-2" style="color: var(--clr-primary)"></i>الإشعارات
            </h1>
            <p class="text-muted mb-0">
                @if (Model.UnreadCount > 0)
                {
                    <span class="badge rounded-pill" style="background-color: var(--clr-accent);">@Model.UnreadCount</span>
                    <span>إشعار غير مقروء</span>
                }
                else
                {
                    <span>لا توجد إشعارات جديدة</span>
                }
            </p>
        </div>
        @if (Model.UnreadCount > 0)
        {
            <form asp-action="MarkAllRead" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary rounded-pill">
                    <i class="bi bi-check-all ms-1"></i>تعليم الكل كمقروء
                </button>
            </form>
        }
    </div>

    @if (Model.Notifications.Count == 0)
    {
        @* ===== EMPTY STATE ===== *@
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="bi bi-bell-slash display-1 text-muted"></i>
            </div>
            <h4 class="text-muted mb-3">لا توجد إشعارات</h4>
            <p class="text-muted mb-4">ستظهر إشعاراتك هنا عند تفعيل تنبيهات الأسهم</p>
            <a asp-controller="Alert" asp-action="Index" class="btn btn-primary rounded-pill px-4"
               style="background-color: var(--clr-primary); border-color: var(--clr-primary);">
                <i class="bi bi-bell ms-1"></i>إدارة التنبيهات
            </a>
        </div>
    }
    else
    {
        @* ===== NOTIFICATION LIST ===== *@
        <div class="list-group list-group-flush">
            @foreach (var notification in Model.Notifications)
            {
                <div class="list-group-item border-0 border-bottom px-0 py-3 @(notification.IsRead ? "" : "bg-light bg-opacity-10")">
                    <div class="d-flex gap-3">
                        @* Icon *@
                        <div class="flex-shrink-0">
                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                 style="width: 48px; height: 48px; background-color: @(notification.IsRead ? "var(--clr-light)" : "var(--clr-primary)"); color: @(notification.IsRead ? "var(--clr-dark)" : "#fff");">
                                <i class="bi @notification.TypeIcon fs-5"></i>
                            </div>
                        </div>

                        @* Content *@
                        <div class="flex-grow-1 min-width-0">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <h6 class="mb-0 @(notification.IsRead ? "text-muted" : "fw-bold")">
                                    @notification.Title
                                </h6>
                                <small class="text-muted text-nowrap me-2">@notification.TimeAgo</small>
                            </div>
                            <p class="mb-1 small @(notification.IsRead ? "text-muted" : "")">
                                @notification.Body
                            </p>

                            @* Actions *@
                            <div class="d-flex gap-2 mt-2">
                                @if (!notification.IsRead)
                                {
                                    <form asp-action="MarkRead" asp-route-id="@notification.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-primary rounded-pill">
                                            <i class="bi bi-check ms-1"></i>تعليم كمقروء
                                        </button>
                                    </form>
                                }
                                @if (!string.IsNullOrEmpty(notification.ReferenceId))
                                {
                                    <a asp-controller="Stock" asp-action="Detail" asp-route-symbol="@notification.ReferenceId"
                                       class="btn btn-sm btn-outline-secondary rounded-pill">
                                        <i class="bi bi-arrow-left ms-1"></i>عرض السهم
                                    </a>
                                }
                            </div>
                        </div>

                        @* Unread Indicator *@
                        @if (!notification.IsRead)
                        {
                            <div class="flex-shrink-0 align-self-center">
                                <span class="badge rounded-pill p-1" style="background-color: var(--clr-accent); width: 10px; height: 10px;"></span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
